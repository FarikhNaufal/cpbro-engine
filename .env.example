# ==================================================
# cryptobroV3 - Environment Configuration Template
# ==================================================

# APP
APP_ENV=local
APP_VERSION=0.1.0
APP_NAME=cryptobroV3
HTTP_PORT=8080
STORAGE_PATH=storage

# SCANNER
SCAN_ENABLED=true
SCAN_INTERVAL_MODE=m15_close
SCAN_STARTUP_DELAY_SECONDS=5
SCAN_CONTEXT_TIMEOUT_SECONDS=120
PREVENT_SCAN_OVERLAP=true
SCAN_CLOSE_CANDLE_BUFFER_SECONDS=3

# MONITORING
MONITORING_ENABLED=true
MONITORING_INTERVAL_SECONDS=60
MONITORING_MAX_HOLD_MINUTES=120
MONITORING_MAX_HOLD_M15_CANDLES=8

# EVALUATION
EVALUATION_ENABLED=true
EVALUATION_AUTO_RUN=false
EVALUATION_AUTO_APPLY=false
EVALUATION_INTERVAL_MINUTES=360
EVALUATION_MIN_SAMPLE_WARNING=10
EVALUATION_MIN_SAMPLE_MEDIUM=20
EVALUATION_MIN_SAMPLE_HIGH=50

# BINANCE READ ONLY (No transaction secrets)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_BASE_URL=https://fapi.binance.com
BINANCE_REQUEST_TIMEOUT_SECONDS=15
BINANCE_MAX_RETRY=2
BINANCE_RETRY_BACKOFF_MS=300

# AI / GEMINI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_REQUEST_TIMEOUT_SECONDS=25
MAX_AI_CONCURRENCY=2
MAX_AI_CANDIDATES_DEFAULT=3
AI_AUDIT_ENABLED=true

# TELEGRAM
TELEGRAM_ENABLED=false
TELEGRAM_SIGNAL_ENABLED=true
TELEGRAM_STATUS_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_SIGNAL_CHAT_ID=
TELEGRAM_STATUS_CHAT_ID=
TELEGRAM_STATUS_ALLOW_SIGNAL_CHAT_FALLBACK=false
TELEGRAM_REQUEST_TIMEOUT_SECONDS=10
TELEGRAM_OPS_BOOT_ENABLED=true
TELEGRAM_OPS_SCAN_ENABLED=false
TELEGRAM_OPS_ADMIN_ENABLED=false

# CONCURRENCY
MAX_MARKETDATA_CONCURRENCY=10
MAX_SYMBOLS_DEFAULT=75

# DEBUG
DEBUG_SAVE_RAW_KLINES=false
RAW_KLINES_DEBUG_DIR=debug/klines

# POCKETBASE (optional persistence for signal_journals + evaluation_runs)
POCKETBASE_ENABLED=false
POCKETBASE_URL=http://127.0.0.1:8090
# Choose exactly one auth method:
# 1) Static token
POCKETBASE_TOKEN=
# 2) Superuser login
POCKETBASE_SUPERUSER_EMAIL=
POCKETBASE_SUPERUSER_PASSWORD=
# 3) Admin login (legacy PocketBase)
POCKETBASE_ADMIN_EMAIL=
POCKETBASE_ADMIN_PASSWORD=
POCKETBASE_REQUEST_TIMEOUT_SECONDS=10
# Auto re-login attempts on 401/403 (0 disables, max 3)
POCKETBASE_LOGIN_RETRY_MAX=1

# STORAGE FILES
LATEST_RESULT_FILE=latest_result.json
SIGNAL_HISTORY_FILE=signal_history.json
SIGNAL_JOURNAL_FILE=signal_journal.json
AI_AUDIT_CACHE_FILE=ai_audit_cache.json
EVALUATION_REPORT_FILE=evaluation_report.json
DECISION_AUDIT_FILE=decision_audit.json
HEALTH_SNAPSHOT_FILE=health_snapshot.json

# SAFETY (CRITICAL: Do not weaken in production)
ALERT_ONLY=true
BINANCE_READ_ONLY=true
ALLOW_BINANCE_WRITE=false
DISABLE_BINANCE_ORDER_ENDPOINTS=true
DISABLE_AUTO_EXECUTION=true
DISABLE_AUTO_THRESHOLD_APPLY=true
REQUIRE_AI_HIGH_FOR_EXECUTE=true
REQUIRE_FRESH_ENTRY_FOR_EXECUTE=true
DECISION_AUDIT_ENABLED=true
HEALTH_STORAGE_CHECK=true

# LOGGING
LOG_LEVEL=info
LOG_FORMAT=json
LOG_INCLUDE_SCAN_ID=true

# ROUTE
API_PREFIX=/api/v3
ENABLE_DECISION_AUDIT_ENDPOINT=true
ENABLE_EVALUATION_RUN_ENDPOINT=true
SWAGGER_ENABLED=true
# Optional. If empty/unset, defaults to "localhost:${HTTP_PORT}".
SWAGGER_HOST=
SWAGGER_BASE_PATH=/api/v3
